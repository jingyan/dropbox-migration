# Dropbox OAuth — use refresh token for long migrations (recommended)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Short-lived access token (expires ~4 hours; not suitable for large migrations)
# DROPBOX_ACCESS_TOKEN=

# Google OAuth app credentials (Desktop app type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional: load all credentials from AWS Secrets Manager instead of env vars above
# SECRETS_MANAGER_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:dropbox-to-gdrive

# Migration scope
DROPBOX_ROOT_PATH=
GDRIVE_ROOT_FOLDER_ID=root
GDRIVE_ROOT_FOLDER_NAME=Dropbox Migration

# Checkpoint for resume support (local file or S3)
CHECKPOINT_URI=file:///tmp/checkpoint.json
# CHECKPOINT_URI=s3://my-bucket/migrations/checkpoint.json

# AWS
AWS_REGION=us-east-1

# Job behavior
DRY_RUN=false
MAX_RETRIES=5
CHUNK_SIZE_MB=8
LOG_LEVEL=INFO

# Network (optional — use if Google APIs time out on your network)
# GOOGLE_PROXY takes precedence over HTTPS_PROXY for Google API calls only
# GOOGLE_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# For SOCKS proxies (Clash/V2Ray): socks5h://127.0.0.1:7891
# GOOGLE_HTTP_TIMEOUT=60
